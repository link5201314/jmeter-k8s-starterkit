# 忽略自動生成的分割 CSV 目錄
scenario/dataset/_split/

# 報告資料夾
report/

# 忽略執行用的暫時腳本
scenario/**/jmeter_injector_start.sh
scenario/**/load_test.sh

# Helm dependency build 產生的套件快取
k8s/helm/charts/*.tgz

# Python virtual environment
.venv/
.venv312/

# Python cache / bytecode
__pycache__/
*.pyc

# Webapp runtime artifacts (keep directories via .gitkeep)
webapp/data/*
!webapp/data/.gitkeep
webapp/logs/*
!webapp/logs/.gitkeep
webapp/tmp/*
!webapp/tmp/.gitkeep
