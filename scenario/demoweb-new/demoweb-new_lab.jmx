def label = prev.getSampleLabel()
//prev.setSampleLabel(tg + &quot;_&quot; + prev.getSampleLabel())

if (label != &apos;rmDesktop&apos; &amp;&amp;  label != &apos;menu&apos; &amp;&amp;  label != &apos;printer&apos; &amp;&amp;  label != &apos;onTimer&apos;) {
