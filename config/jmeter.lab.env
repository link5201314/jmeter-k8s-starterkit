# Lab environment runtime JVM config
JMETER_MASTER_JVM_HEAP_ARGS="-Xms256m -Xmx512m"
JMETER_SLAVE_JVM_HEAP_ARGS="-Xms128m -Xmx256m"
JMETER_JOLOKIA_DEBUG="false"

# Lab runtime resource override (used by start_test.sh run values)
# Keep requests low so master + 5 slaves can be scheduled on constrained nodes.
JMETER_MASTER_REQUEST_CPU="300m"
JMETER_MASTER_LIMIT_CPU="600m"
JMETER_MASTER_REQUEST_MEMORY="256Mi"
JMETER_MASTER_LIMIT_MEMORY="512Mi"
JMETER_SLAVE_REQUEST_CPU="200m"
JMETER_SLAVE_LIMIT_CPU="400m"
JMETER_SLAVE_REQUEST_MEMORY="128Mi"
JMETER_SLAVE_LIMIT_MEMORY="384Mi"
JMETER_FLASHBACK_DB_API="http://flashback-api.lab.svc.cluster.local"
