# (刪除原本的 `// filepath: ...` 行，改用 # 註解格式)

JMETER_MASTER_REQUEST_CPU=1024m
JMETER_MASTER_LIMIT_CPU=1024m
JMETER_MASTER_REQUEST_MEMORY=1024Mi
JMETER_MASTER_LIMIT_MEMORY=2048Mi

JMETER_SLAVE_REQUEST_CPU=1024m
JMETER_SLAVE_LIMIT_CPU=1024m
JMETER_SLAVE_REQUEST_MEMORY=1024Mi
JMETER_SLAVE_LIMIT_MEMORY=1024Mi

JMETER_MASTER_JVM_HEAP_ARGS=-Xms1024m -Xmx1024m
JMETER_SLAVE_JVM_HEAP_ARGS=-Xms1024m -Xmx1024m
