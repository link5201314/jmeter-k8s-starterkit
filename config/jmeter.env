# Common fallback runtime env file.
# Priority in start_test.sh:
# 1) --jmeter-env-file
# 2) config/jmeter.<helm-env>.env
# 3) config/jmeter.env (this file)

# JVM heap (recommended to keep per-environment in config/jmeter.<env>.env)
JMETER_MASTER_JVM_HEAP_ARGS="-Xms1024m -Xmx1024m"
JMETER_SLAVE_JVM_HEAP_ARGS="-Xms1024m -Xmx1024m"

# Runtime plugin install mode for PluginsManagerCMD.sh
# auto   : try install only when DNS can resolve jmeter-plugins.org
# always : always try install (requires egress + DNS)
# never  : never install at runtime, rely on plugins bundled in image
JMETER_PLUGIN_INSTALL_MODE="auto"

# Optional legacy runtime resource overrides (normally managed by Helm values)
# JMETER_MASTER_REQUEST_CPU=1024m
# JMETER_MASTER_LIMIT_CPU=1024m
# JMETER_MASTER_REQUEST_MEMORY=1024Mi
# JMETER_MASTER_LIMIT_MEMORY=2048Mi
# JMETER_SLAVE_REQUEST_CPU=1024m
# JMETER_SLAVE_LIMIT_CPU=1024m
# JMETER_SLAVE_REQUEST_MEMORY=1024Mi
# JMETER_SLAVE_LIMIT_MEMORY=1024Mi
